{
  "name": "retirement-path-comparison-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "cluster:dispatcher": "tsx cluster/dispatcher.ts",
    "cluster:smoke": "tsx cluster/smoke-client.ts",
    "cluster:host": "tsx cluster/host.ts",
    "cluster:host-smoke": "tsx cluster/host-smoke.ts",
    "cluster:start-session": "tsx cluster/start-session.ts",
    "wasm:build": "cd flight-engine-rs && wasm-pack build --target web --release --out-dir ../src/wasm",
    "wasm:dev": "cd flight-engine-rs && wasm-pack build --target web --dev --out-dir ../src/wasm"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.34.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.2.4",
    "ws": "^8.20.0"
  }
}

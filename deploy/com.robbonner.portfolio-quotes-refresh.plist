<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.robbonner.portfolio-quotes-refresh</string>

  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>--import</string>
    <string>tsx</string>
    <string>scripts/refresh-portfolio-quotes.ts</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/robbonner/retirement-calculator</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StartInterval</key>
  <integer>3600</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/robbonner/worker-logs/portfolio-quotes-refresh.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/robbonner/worker-logs/portfolio-quotes-refresh.err.log</string>
</dict>
</plist>

# /etc/default/cluster
# Sourced by every systemd unit (dispatcher + host@*). Reload after edits:
#   sudo systemctl restart cluster-dispatcher 'cluster-host@*'

# --- Auth (REQUIRED for cloud) ----------------------------------------------
# Generate with: openssl rand -hex 32
# Browsers, the controller CLI, and every host must present this.
CLUSTER_AUTH_TOKEN=__REPLACE_ME__

# --- Dispatcher --------------------------------------------------------------
# Caddy proxies to this; do not expose 8765 to the internet.
DISPATCHER_PORT=8765
# Persisted corpus. /var/lib/cluster is created by bootstrap.sh.
CLUSTER_DATA_DIR=/var/lib/cluster/data

# --- Host (per-instance defaults; override in unit overrides if needed) ------
# Local dispatcher — hosts on the same box use loopback, no token needed
# strictly speaking, but we send it anyway so the same env file works.
DISPATCHER_URL=ws://localhost:8765
# Worker count per host process. With multiple host@N units running on one
# box, set this to (vCPUs / N) - 1 leaving room for the dispatcher and OS.
HOST_WORKERS=4
HOST_PERF_CLASS=x86-modern
